{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: g++ build project",
      "command": "/usr/bin/g++",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${workspaceFolder}/src/main.cpp",
        "${workspaceFolder}/src/linkedList.cpp",
        "-I${workspaceFolder}/headers",
        "-o",
        "${workspaceFolder}/.bin/programa"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    }
  ],
  "version": "2.0.0"
}
